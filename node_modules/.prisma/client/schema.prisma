datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleName {
  super_admin
  admin
  responder
  gbv_officer
  counsellor
  developer
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?
  users       User[]
}

model User {
  id             String   @id @default(uuid())
  first_name     String
  last_name      String
  email          String   @unique
  phone          String?
  password_hash  String
  role_id        String
  province       String?
  district       String?
  email_verified Boolean  @default(false)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  refreshTokenId String?  @unique

  role Role @relation(fields: [role_id], references: [id])
}

model Province {
  id        String     @id @default(uuid())
  name      String     @unique
  districts District[]
}

model District {
  id          String   @id @default(uuid())
  name        String
  province_id String
  province    Province @relation(fields: [province_id], references: [id])
}

enum FacilityType {
  clinic
  hospital
  shelter
  responder_hub
}

model Facility {
  id         String       @id @default(uuid())
  name       String       @unique
  type       FacilityType
  province   String
  district   String
  address    String?
  latitude   Float?
  longitude  Float?
  phone      String?
  is_active  Boolean      @default(true)
  created_at DateTime     @default(now())
}

model LearningCategory {
  id          String            @id @default(uuid())
  title       String
  description String?
  articles    LearningArticle[]
}

model LearningArticle {
  id             String  @id @default(uuid())
  category_id    String
  title          String
  summary        String?
  content        String?
  featured_image String?
  language       String?
  published      Boolean @default(false)

  category LearningCategory @relation(fields: [category_id], references: [id])
}

// Phase 3 – Reports & SOS (already present, now adding status enum)
enum ReportStatus {
  New
  Assigned
  In_Progress
  Resolved
  Closed
}

model Report {
  id             String       @id @default(uuid())
  case_number    String?
  category       String
  description    String?
  province       String?
  district       String?
  gps_location   String?
  reporter_name  String?
  reporter_phone String?
  status         ReportStatus @default(New)
  priority       String       @default("Low")
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  attachments Attachment[]
  assignments ReportAssignment[]
  sos_alerts  SosAlert[]
}

model Attachment {
  id        String @id @default(uuid())
  report_id String
  file_url  String
  file_type String

  report Report @relation(fields: [report_id], references: [id])
}

model SosAlert {
  id         String   @id @default(uuid())
  report_id  String?
  location   String?
  phone      String?
  created_at DateTime @default(now())

  report Report? @relation(fields: [report_id], references: [id])
}

// Phase 4 – Assignment System
model ReportAssignment {
  id           String       @id @default(uuid())
  report_id    String
  responder_id String
  assigned_by  String
  status       ReportStatus @default(Assigned)
  assigned_at  DateTime     @default(now())

  report Report @relation(fields: [report_id], references: [id])
}
